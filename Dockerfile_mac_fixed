FROM python:3.11-slim

WORKDIR /app

ENV PIP_NO_CACHE_DIR=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    git \
    pkg-config \
    libboost-all-dev \
 && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .

# Install dependencies, making gmdh optional since GMDH is disabled by default in the code
RUN pip install --upgrade pip setuptools wheel \
 && pip install -r requirements.txt \
 && (pip install gmdh || echo "Warning: gmdh installation failed, continuing without it")

COPY . .

EXPOSE 8501
ENTRYPOINT ["streamlit", "run", "Portfolio_optimization.py", "--server.port=8501", "--server.address=0.0.0.0"]
