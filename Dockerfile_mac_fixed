FROM python:3.11-slim

WORKDIR /app

ENV PIP_NO_CACHE_DIR=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    git \
    pkg-config \
    libboost-all-dev \
 && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .

# Install all dependencies except gmdh (which may fail to build on some architectures)
RUN pip install --upgrade pip setuptools wheel \
 && grep -v '^gmdh' requirements.txt > requirements_no_gmdh.txt \
 && pip install -r requirements_no_gmdh.txt \
 && (pip install gmdh==1.0.3 || echo "Warning: gmdh installation failed, GMDH models will be unavailable")

COPY . .

EXPOSE 8501
ENTRYPOINT ["streamlit", "run", "Portfolio_optimization.py", "--server.port=8501", "--server.address=0.0.0.0"]
